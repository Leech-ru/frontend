{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "projects": {
    "frontend": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "i18n": {
        "sourceLocale": "ru",
        "locales": {
          "en": "src/shared/i18n/locales/messages.en.xlf"
        }
      },
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": "dist/frontend",
            "localize": ["ru", "en"],
            "index": "src/app/index.html",
            "browser": "src/app/entry.browser.ts",
            "tsConfig": "tsconfig.json",
            "inlineStyleLanguage": "less",
            "assets": [
              {
                "glob": "**/*",
                "input": "public",
                "output": "/"
              },
              {
                "glob": "**/*",
                "input": "node_modules/@taiga-ui/icons/src",
                "output": "assets/taiga-ui/icons"
              }
            ],
            "styles": [
              "@taiga-ui/styles/taiga-ui-theme.less",
              "@taiga-ui/styles/taiga-ui-fonts.less",
              "@taiga-ui/addon-mobile/styles/taiga-ui-mobile.less",
              "src/app/index.less"
            ],
            "server": "src/app/entry.server.ts",
            "prerender": true,
            "ssr": {
              "entry": "src/app/entry.ssr.ts"
            },
            "polyfills": ["@angular/localize/init"]
          },
          "configurations": {
            "production": {
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "sourceMap": true
            },
            "ru": {
              "localize": ["ru"]
            },
            "en": {
              "localize": ["en"]
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "frontend:build:production"
            },
            "development": {
              "buildTarget": "frontend:build:development"
            },
            "ru": {
              "buildTarget": "frontend:build:development,ru"
            },
            "en": {
              "buildTarget": "frontend:build:development,en"
            }
          },
          "options": {
            "proxyConfig": "src/app/proxy.ts"
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular/build:extract-i18n",
          "options": {
            "outputPath": "src/shared/i18n/locales"
          }
        }
      }
    }
  },
  "cli": {
    "analytics": false
  }
}
