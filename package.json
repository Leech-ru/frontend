{
  "name": "@leech-ru/frontend",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "ng build",
    "format": "prettier !package-lock.json --check --write --ignore-path .gitignore .",
    "prepare": "git config core.hooksPath ./scripts/git/hooks",
    "serve": "ng serve",
    "start": "node dist/frontend/server/server.mjs"
  },
  "prettier": {
    "endOfLine": "lf",
    "printWidth": 80,
    "semi": true,
    "singleQuote": false,
    "tabWidth": 2,
    "trailingComma": "all",
    "useTabs": false,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "dependencies": {
    "@angular/build": "^21.2.7",
    "@angular/cdk": "^21.2.5",
    "@angular/cli": "^21.2.7",
    "@angular/common": "^21.2.8",
    "@angular/compiler": "^21.2.8",
    "@angular/compiler-cli": "^21.2.8",
    "@angular/core": "^21.2.8",
    "@angular/forms": "^21.2.8",
    "@angular/platform-browser": "^21.2.8",
    "@angular/platform-server": "^21.2.8",
    "@angular/router": "^21.2.8",
    "@angular/ssr": "^21.2.7",
    "@maskito/angular": "^5.2.2",
    "@maskito/core": "^5.2.2",
    "@maskito/kit": "^5.2.2",
    "@maskito/phone": "^5.2.2",
    "@ng-web-apis/platform": "^5.2.0",
    "@ng-web-apis/universal": "^5.2.0",
    "@taiga-ui/addon-commerce": "^5.1.0",
    "@taiga-ui/addon-mobile": "^5.1.0",
    "@taiga-ui/addon-table": "^5.1.0",
    "@taiga-ui/cdk": "^5.1.0",
    "@taiga-ui/core": "^5.1.0",
    "@taiga-ui/i18n": "^5.1.0",
    "@taiga-ui/icons": "^5.1.0",
    "@taiga-ui/kit": "^5.1.0",
    "@taiga-ui/layout": "^5.1.0",
    "@taiga-ui/styles": "^5.1.0",
    "@types/express": "^5.0.6",
    "@types/node": "^24.11.0",
    "embla-carousel": "^8.6.0",
    "embla-carousel-angular": "^21.0.0",
    "express": "^5.2.1",
    "less": "^4.6.4",
    "prettier": "^3.8.1",
    "rxjs": "^7.8.2",
    "typescript": "^5.9.0"
  }
}
